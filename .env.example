# Auth (generate a strong secret with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-app.azurewebsites.net

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# PostgreSQL TLS (production)
# Provide the CA certificate content (preferred — copy from Azure portal or managed service)
# DATABASE_CA_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# Fallback: set to 'false' only if CA cert is unavailable (e.g., self-signed cert environments)
# SQL_TLS_REJECT_UNAUTHORIZED=false
